<link rel="stylesheet" href="/css/chronicles.css">
<article class="bento-tile col-span-1 md:col-span-3 min-h-[60vh] flex flex-col overflow-hidden relative group">

    <!-- Subtle grid texture -->
    <div class="absolute inset-0 bg-[url('data:image/svg+xml;base64,PHN2ZyB3aWR0aD0iMjAiIGhlaWdodD0iMjAiIHhtbG5zPSJodHRwOi8vd3d3LnczLm9yZy8yMDAwL3N2ZyI+PHBhdGggZD0iTTEgMWgyMHYyMEgxVjF6IiBmaWxsPSJub25lIiBzdHJva2U9InJnYmEoMjEyLCAxNzUsIDU1LCAwLjAzKSIgc3Ryb2tlLXdpZHRoPSIxIi8+PC9zdmc+')] opacity-50 z-0"></div>

    <!-- Sticky header -->
    <div class="bento-header sticky top-0 bg-[#1A0F0F]/90 backdrop-blur z-20 shadow-sm border-b border-sanctum-accent/20">
        <a href="/" class="text-sanctum-text/60 hover:text-sanctum-accent text-xs uppercase tracking-widest flex items-center gap-2 transition-all font-bold">
            <div class="w-6 h-6 rounded-full bg-sanctum-bg border border-sanctum-accent/30 flex items-center justify-center group-hover:bg-sanctum-accent/10 transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
                </svg>
            </div>
            Return to Sanctum
        </a>
        <div class="technical text-sanctum-text/50 text-[10px]">THE_CHRONICLES</div>
    </div>

    <div class="relative z-10 flex-1 w-full p-8 md:p-12 lg:p-16">

        <!-- Page header -->
        <header class="text-center mb-16">
            <div class="chronicles-header-eyebrow mb-6">
                <span class="technical">SANCTUM_ARCHIVE</span>
                <span class="chronicles-rule"></span>
                <span class="technical">ENTRY_LOG</span>
            </div>
            <h1 class="chronicles-title">The Chronicles</h1>
            <div class="h-[1px] w-24 bg-sanctum-accent mx-auto mb-6 opacity-30"></div>
            <p class="chronicles-subtitle">Expedition logs, conceptual dispatches, and structural observations — rendered from raw manuscript.</p>
        </header>

        <!-- Post list -->
        <% if (posts.length === 0) { %>
            <div class="text-center py-16">
                <p class="technical text-[#B5935B]/40 text-xs tracking-widest uppercase mb-3">NO_ENTRIES_INDEXED</p>
                <p class="font-serif text-[#F4F1EA]/30 text-lg italic">The archive is awaiting its first manuscript.</p>
            </div>
        <% } else { %>
            <ul class="chronicles-list max-w-3xl mx-auto" role="list">
                <% posts.forEach((post, i) => { %>
                    <li class="chronicle-entry" style="animation-delay: <%= i * 80 %>ms">
                        <a href="/blog/<%= post.slug %>" class="chronicle-link">

                            <div class="chronicle-meta">
                                <time class="chronicle-date technical" datetime="<%= post.date %>">
                                    <%= new Date(post.date).toLocaleDateString('en-AU', { year: 'numeric', month: 'long', day: 'numeric' }) %>
                                </time>
                                <% if (post.tags && post.tags.length > 0) { %>
                                    <div class="chronicle-tags">
                                        <% post.tags.slice(0, 3).forEach(tag => { %>
                                            <span class="chronicle-tag">#<%= tag %></span>
                                        <% }) %>
                                    </div>
                                <% } %>
                            </div>

                            <h2 class="chronicle-entry-title"><%= post.title %></h2>

                            <% if (post.description) { %>
                                <p class="chronicle-excerpt"><%= post.description %></p>
                            <% } %>

                            <div class="chronicle-read-more">
                                <span>Read Manuscript</span>
                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                            </div>

                        </a>
                    </li>
                <% }) %>
            </ul>
        <% } %>

    </div>
</article>
