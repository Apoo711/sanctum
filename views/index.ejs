<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 auto-rows-[280px]">
    
    <!-- TILE: THE ORRERY (2x2) -->
    <div class="bento-tile col-span-1 md:col-span-2 row-span-2">
        <div class="bento-header">
            <h2><span class="status-dot"></span>THE ORRERY</h2>
            <span class="metadata">PHYSICS ENGINE</span>
        </div>
        <div class="flex-1 relative flex items-center justify-center">
            <canvas id="orrery" class="w-full h-full cursor-crosshair"></canvas>
            <!-- Background Axes -->
            <div class="absolute inset-0 flex items-center justify-center pointer-events-none opacity-5">
                <div class="w-full h-[1px] bg-white"></div>
                <div class="h-full w-[1px] bg-white absolute"></div>
            </div>
        </div>
        <div class="absolute bottom-6 right-6 metadata opacity-40">
            R.A. 14h 29m 43s | Dec −62° 40′ 46″
        </div>
    </div>

    <!-- TILE: VCE EPHEMERIS -->
    <div class="bento-tile">
        <div class="bento-header">
            <h2>VCE EPHEMERIS</h2>
            <span class="metadata">EPOCH_TRACKER</span>
        </div>
        <div class="flex-1 flex flex-col justify-center p-4">
            <div class="text-xs uppercase tracking-widest text-sanctum-accent/50 mb-2">October 26, 2026</div>
            <div id="vce-countdown" class="grid grid-cols-4 gap-2 text-center text-3xl font-mono tracking-tighter">
                <!-- Data populated via JS -->
            </div>
            <div class="grid grid-cols-4 gap-2 text-center mt-4 pt-4 border-t border-sanctum-accent/10 metadata vce-label text-xs font-bold">
                <span>DAYS</span><span>HOURS</span><span>MINS</span><span>SECS</span>
            </div>
        </div>
    </div>

    <!-- TILE: TACTICS (CHESS) -->
    <div class="bento-tile">
        <div class="bento-header">
            <h2>TACTICS</h2>
            <div class="flex gap-2">
                <button class="mode-btn" data-mode="BULLET">BULLET</button>
                <button class="mode-btn" data-mode="BLITZ">BLITZ</button>
                <button class="mode-btn active" data-mode="RAPID">RAPID</button>
            </div>
        </div>
        <div class="flex-1 flex flex-col items-center justify-center">
            <!-- Chess.com Puzzle Icon SVG -->
            <div class="w-16 h-16 flex items-center justify-center mb-4 group-hover:scale-110 transition-transform">
                <svg viewBox="0 0 100 100" class="w-full h-full" fill="none" stroke="#B5935B" stroke-width="3">
                    <circle cx="50" cy="50" r="40" stroke-dasharray="10 5" opacity="0.4" />
                    <path d="M50 10 V30 M50 70 V90 M10 50 H30 M70 50 H90" />
                    <circle cx="50" cy="50" r="15" fill="#B5935B" fill-opacity="0.1" />
                    <path d="M40 50 L50 40 L60 50 L50 60 Z" fill="#B5935B" />
                </svg>
            </div>
            <div id="chess-rating" class="text-4xl font-serif mb-1">...</div>
            <div id="chess-label" class="metadata text-[9px] opacity-60 uppercase">RAPID RATING // ARYAN18GUPTA</div>
        </div>
    </div>

    <!-- TILE: THE SCRIPTORIUM -->
    <div class="bento-tile col-span-1 md:col-span-3">
        <div class="bento-header">
            <h2>THE SCRIPTORIUM</h2>
            <span class="metadata">EPHEMERAL_MANUSCRIPT</span>
        </div>
        <div class="h-48 rounded-lg bg-[#F4F1EA] shadow-inner flex overflow-hidden">
            <div class="flex-1 p-8 flex items-center justify-center text-3xl text-[#1A1A1A] font-serif">
                <!-- Main Math Display -->
                <div id="math-output"></div>
            </div>
            <div class="w-64 p-6 bg-black/5 border-l border-black/10 flex flex-col justify-between">
                <div>
                    <span class="metadata text-[#1A1A1A]/40 block mb-2">DAILY VECTOR</span>
                    <!-- Delimiters added for auto-render -->
                    <p class="text-sm italic text-[#1A1A1A]/80 font-serif">
                        "Compute the circulation of the vector field $\vec{F}$ along the boundary $\partial S$."
                    </p>
                </div>
                <div class="w-10 h-10 rounded-full bg-[#8B0000] self-end shadow-lg flex items-center justify-center text-[10px] font-black text-yellow-500 transform rotate-12">AG</div>
            </div>
        </div>
        <textarea id="math-input" class="hidden">e^{i\pi} + 1 = 0</textarea>
    </div>
</div>