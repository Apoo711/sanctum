<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="<%= locals.description || 'Personal portfolio, laboratory, and digital sanctum.' %>">
    <title><%= locals.title || 'Aryan Gupta | Sanctum' %></title>
    
    <!-- View Transitions API -->
    <meta name="view-transition" content="same-origin">

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700&family=Outfit:wght@300;400;600;800&family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=EB+Garamond:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
    
    <!-- KaTeX Script -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.8/dist/katex.min.css" integrity="sha384-GvrNrr1sR06s4wTjQkHkOqRAn5O11n4v1w1hA5gQ/VONJ0iH6zV4Z/oUv7g0Xlq+" crossorigin="anonymous">
    <script defer src="https://cdn.jsdelivr.net/npm/katex@0.16.8/dist/katex.min.js" integrity="sha384-cpW21h6RZv/phavutF+GqIGc/F2DxliE4s2xV01/cW3h5mJ2/T0a/a47XwE1Gz" crossorigin="anonymous"></script>
    <script defer src="https://cdn.jsdelivr.net/npm/katex@0.16.8/dist/contrib/auto-render.min.js" integrity="sha384-+VBxd3r6XgURycqtZ117b98586k1E+O2x02Q1EIFhBpeqKz/fB6CWeBSt6A//wzB" crossorigin="anonymous"></script>
    <script>document.addEventListener("DOMContentLoaded", function() { renderMathInElement(document.body, { delimiters: [{left: "$$", right: "$$", display: true}, {left: "$", right: "$", display: false}, {left: "\\(", right: "\\)", display: false}, {left: "\\[", right: "\\]", display: true}] }); });</script>

    <!-- Tailwind Play CDN -->
    <script src="https://cdn.tailwindcss.com?plugins=typography"></script>
    <script>
        tailwind.config = { 
            theme: { 
                extend: { 
                    colors: { 
                        'sanctum-accent': '#B5935B', 
                        'sanctum-text': '#F4F1EA', 
                        'sanctum-dark': '#020202' 
                    } 
                } 
            } 
        }
    </script>
    <link rel="stylesheet" type="text/css" href="/css/theme.css">
    <link rel="stylesheet" type="text/css" href="/css/components.css">
    <link rel="stylesheet" type="text/css" href="/css/instruments.css">
    <link rel="stylesheet" type="text/css" href="/css/prospectus.css">
</head>
<body class="p-4 md:p-8 lg:p-12 relative flex flex-col items-center justify-center min-h-screen overflow-x-hidden">
    <!-- Subtle background glow -->
    <div class="fixed top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] md:w-[800px] md:h-[800px] bg-sanctum-accent/5 rounded-full blur-[100px] md:blur-[150px] pointer-events-none -z-10"></div>
    
    <!-- The Secret Sidebar (Compass Navigation) -->
    <nav id="sidebar" class="nav-sidebar group">
        
        <!-- Logo/Astrolabe anchor -->
        <div class="w-10 h-10 min-w-10 rounded-full border-[0.5px] border-sanctum-accent flex justify-center items-center relative group-hover:rotate-90 transition-transform duration-700">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#B5935B" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-compass"><circle cx="12" cy="12" r="10"/><polygon points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76"/></svg>
        </div>

        <div class="flex-1 flex flex-col items-start w-full px-5 md:px-7 mt-8 gap-10">
            <a href="/blog" class="flex items-center gap-6 w-full text-[#B5935B]/60 hover:text-[#B5935B] hover:drop-shadow-[0_0_8px_rgba(181,147,91,0.8)] font-serif tracking-widest text-xs uppercase" aria-label="Archives" style="white-space: nowrap;">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-book-open min-w-5"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
                <span class="opacity-0 group-hover:opacity-100 text-[#B5935B]" style="white-space: nowrap; transition: opacity 0.3s ease-in-out;">The Chronicles</span>
            </a>
            
            <a href="/resources" class="flex items-center gap-6 w-full text-[#B5935B]/60 hover:text-[#B5935B] hover:drop-shadow-[0_0_8px_rgba(181,147,91,0.8)] font-serif tracking-widest text-xs uppercase" aria-label="Laboratory" style="white-space: nowrap;">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-flask-conical min-w-5"><path d="M10 2v7.527a2 2 0 0 0 .586 1.414l5.828 5.828A2 2 0 0 1 15 19.59V22h-6v-2.41a2 2 0 0 1 .586-1.414l5.828-5.828A2 2 0 0 0 16 9.527V2h-6z"/><path d="M8.5 2h7"/><path d="M10.5 14h3"/></svg>
                <span class="opacity-0 group-hover:opacity-100 text-[#B5935B]" style="white-space: nowrap; transition: opacity 0.3s ease-in-out;">The Scriptorium</span>
            </a>
            
            <button id="prospectus-btn" class="flex items-center gap-6 w-full text-[#B5935B]/60 hover:text-[#B5935B] hover:drop-shadow-[0_0_8px_rgba(181,147,91,0.8)] font-serif tracking-widest text-xs uppercase outline-none" aria-label="Prospectus" style="white-space: nowrap;">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-stamp min-w-5"><path d="M5 22h14"/><path d="M19.27 13.73A2.5 2.5 0 0 0 17.5 13h-11A2.5 2.5 0 0 0 4 15.5V17a1 1 0 0 0 1 1h14a1 1 0 0 0 1-1v-1.5c0-.66-.26-1.3-.73-1.77Z"/><path d="M14 13V8.5C14 7 15 7 15 5a3 3 0 0 0-3-3c-1.66 0-3 1.34-3 3 0 2 1 2 1 3.5V13"/></svg>
                <span class="opacity-0 group-hover:opacity-100 text-[#B5935B]" style="white-space: nowrap; transition: opacity 0.3s ease-in-out;">Prospectus</span>
            </button>
        </div>
        
        <!-- Bottom ornamental scroll -->
        <div class="mb-4">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="rgba(181, 147, 91, 0.4)" stroke-width="1" class="group-hover:stroke-[#B5935B] transition-colors"><path d="M12 2v20 M7 7l5-5 5 5 M7 17l5 5 5-5"/></svg>
        </div>
    </nav>
    
    <!-- The Prospectus Overlay Fix -->
    <div id="prospectus-overlay" class="hidden flex flex-col items-center justify-center p-8 md:p-16 custom-scrollbar overflow-y-auto">
        <h2 class="font-serif text-3xl md:text-5xl text-sanctum-accent tracking-widest mb-4 font-bold select-none text-center drop-shadow-lg relative z-10">THE SCHOLAR'S DESK</h2>
        <div class="h-[1px] w-full max-w-4xl bg-gradient-to-r from-transparent via-sanctum-accent/50 to-transparent mb-16 relative z-10"></div>
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 w-full max-w-5xl relative z-10">
            <!-- Passport: Vietnam 2024 -->
            <div class="passport-booklet relative w-full aspect-[1/1.4] cursor-pointer group" onclick="this.classList.toggle('is-open')">
                
                <!-- Inner Pages (Multi-Page Logic) -->
                <div class="absolute inset-0 bg-[#F4F1EA] rounded-r-lg border-l-4 border-black shadow-inner flex flex-col p-4 items-center justify-between z-10 overflow-hidden" onclick="event.stopPropagation()">
                    <!-- Navigation arrows removed in favor of direct clicking -->
                    
                    <!-- Page 1 -->
                    <div id="vietnam-page-1" class="w-full flex-1 flex flex-col items-center justify-center passport-page active">
                        <p class="font-serif text-[#1A1A1A] text-sm text-center font-bold">Expedition Logs<br><span class="text-xs font-mono font-normal opacity-50 mt-2 block">Infrastructure Deployment: Assisted in the manual construction of 4.2km of rural transit arteries in the Mekong region.</span></p>
                    </div>
                    <!-- Page 2 -->
                    <div id="vietnam-page-2" class="w-full flex-1 flex flex-col items-center justify-center passport-page hidden">
                        <p class="font-serif text-[#1A1A1A] text-sm text-center font-bold">Road-Building Log<br><span class="text-xs font-mono font-normal opacity-50 mt-2 block">Infrastructure Deployment: Assisted in the manual construction of 4.2km of rural transit arteries in the Mekong region.</span></p>
                    </div>
                    <!-- Page 3 -->
                    <div id="vietnam-page-3" class="w-full flex-1 flex flex-col items-center justify-center passport-page hidden">
                        <p class="font-serif text-[#1A1A1A] text-sm text-center font-bold">Field Photography<br><span class="text-xs font-mono font-normal opacity-50 mt-2 block">[Awaiting Asset Integration]</span></p>
                    </div>
                    
                    <div class="font-mono text-[8px] text-[#1A1A1A]/40 tracking-widest mt-auto mb-1">PG. <span id="vietnam-page-nav">1</span></div>
                </div>

                <div class="passport-cover absolute inset-0 bg-[#3A1F1F] rounded-r-lg border-l-4 border-black shadow-[5px_5px_15px_rgba(0,0,0,0.5)] border border-[#1A0F0F] z-20">
                    <!-- Front Cover Content -->
                    <div class="absolute inset-0 flex flex-col items-center justify-center cover-front">
                        <div class="w-12 h-12 border border-[#B5935B]/50 rounded-full mb-4 flex items-center justify-center">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#B5935B" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-plane"><path d="M17.8 19.2 16 11l3.5-3.5C21 6 21.5 4 21 3c-1-.5-3 0-4.5 1.5L13 8 4.8 6.2c-.5-.1-.9.2-1.1.6L3 8l6 4-3 3-3-1-2 2 4 4 2-2-1-3 3-3 4 6c.4.2.8-.2 1.1-.6l1.2-1.8Z"/></svg>
                        </div>
                        <div class="font-serif text-[#B5935B] text-xl font-bold tracking-widest uppercase">Vietnam</div>
                        <div class="font-mono text-[#B5935B]/50 text-xs tracking-widest mt-2">2024</div>
                    </div>
                    <!-- Inside Cover (Backface) -->
                    <div class="absolute inset-0 bg-[#F4F1EA] cover-back border-r border-[#1A0F0F] shadow-inner flex items-center justify-center">
                        <div class="w-16 h-16 border-2 border-dashed border-[#1A1A1A]/20 rotate-12 flex items-center justify-center opacity-50">
                            <span class="font-mono text-[#1A1A1A]/40 text-[10px] uppercase">Entry Visa</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Passport: Cambodia 2025 -->
            <div class="passport-booklet relative w-full aspect-[1/1.4] cursor-pointer group" onclick="this.classList.toggle('is-open')">
                
                <div class="absolute inset-0 bg-[#F4F1EA] rounded-r-lg border-l-4 border-black shadow-inner flex flex-col p-4 items-center justify-between z-10 overflow-hidden" onclick="event.stopPropagation()">
                    <!-- Navigation arrows removed in favor of direct clicking -->
                    
                    <!-- Page 1 -->
                    <div id="cambodia-page-1" class="w-full flex-1 flex flex-col items-center justify-center passport-page active">
                        <p class="font-serif text-[#1A1A1A] text-sm text-center font-bold">Expedition Logs<br><span class="text-xs font-mono font-normal opacity-50 mt-2 block">Clinical Outreach: Supported rural medical rotations and delivered primary literacy modules to regional students.</span></p>
                    </div>
                    <!-- Page 2 -->
                    <div id="cambodia-page-2" class="w-full flex-1 flex flex-col items-center justify-center passport-page hidden">
                        <p class="font-serif text-[#1A1A1A] text-sm text-center font-bold">Hospital Outreach Log<br><span class="text-xs font-mono font-normal opacity-50 mt-2 block">Clinical Outreach: Supported rural medical rotations and delivered primary literacy modules to regional students.</span></p>
                    </div>
                    <!-- Page 3 -->
                    <div id="cambodia-page-3" class="w-full flex-1 flex flex-col items-center justify-center passport-page hidden">
                        <p class="font-serif text-[#1A1A1A] text-sm text-center font-bold">Clinical Observations<br><span class="text-xs font-mono font-normal opacity-50 mt-2 block">[Field Notes Processing]</span></p>
                    </div>
                    
                    <div class="font-mono text-[8px] text-[#1A1A1A]/40 tracking-widest mt-auto mb-1">PG. <span id="cambodia-page-nav">1</span></div>
                </div>

                <div class="passport-cover absolute inset-0 bg-[#1F2A3A] rounded-r-lg border-l-4 border-black shadow-[5px_5px_15px_rgba(0,0,0,0.5)] border border-[#1A0F0F] z-20">
                    <div class="absolute inset-0 flex flex-col items-center justify-center cover-front">
                        <div class="w-12 h-12 border border-[#B5935B]/50 rounded-full mb-4 flex items-center justify-center">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#B5935B" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-map"><polygon points="3 6 9 3 15 6 21 3 21 18 15 21 9 18 3 21"/><line x1="9" x2="9" y1="3" y2="18"/><line x1="15" x2="15" y1="6" y2="21"/></svg>
                        </div>
                        <div class="font-serif text-[#B5935B] text-xl font-bold tracking-widest uppercase">Cambodia</div>
                        <div class="font-mono text-[#B5935B]/50 text-xs tracking-widest mt-2">2025</div>
                    </div>
                    <div class="absolute inset-0 bg-[#F4F1EA] cover-back border-r border-[#1A0F0F] shadow-inner flex items-center justify-center">
                        <div class="w-16 h-16 border-2 border-dashed border-[#1A1A1A]/20 -rotate-6 flex items-center justify-center opacity-50">
                            <span class="font-mono text-[#1A1A1A]/40 text-[10px] uppercase">Entry Visa</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- V.I.S.O.R Technical Dossier -->
            <div class="relative w-full aspect-[1/1.4] z-10">
                <div class="absolute inset-0 bg-[#0a0a0a] rounded-r-xl border-l-8 border-[#050505] shadow-[8px_8px_20px_rgba(0,0,0,0.8)] flex flex-col p-6 border-y border-r border-[#222]">
                    <!-- Navigation arrows removed in favor of direct clicking -->

                    <!-- Page 1 (Cover) -->
                    <div id="visor-page-1" class="flex-1 w-full border-2 border-[#B5935B]/20 p-4 flex flex-col items-center justify-center text-center relative overflow-hidden active">
                        <div class="absolute inset-0 bg-[#B5935B] opacity-[0.02] mix-blend-overlay pointer-events-none"></div>
                        <div class="w-16 h-16 border border-[#B5935B]/40 flex items-center justify-center rotate-45 mb-6 group-hover:rotate-90 transition-transform duration-1000">
                            <div class="w-8 h-8 bg-[#B5935B]/20 flex items-center justify-center -rotate-45">
                                <span class="font-mono text-[#B5935B] text-xs">V</span>
                            </div>
                        </div>
                        <h3 class="font-sans font-black tracking-tighter text-2xl text-[#F4F1EA] uppercase mb-1 drop-shadow-[0_0_10px_rgba(244,241,234,0.3)]">V.I.S.O.R</h3>
                        <p class="font-serif text-[#F4F1EA]/50 text-xs uppercase tracking-widest">Technical Dossier</p>
                        
                        <div class="mt-auto pt-4 border-t border-[#B5935B]/20 w-full flex justify-end">
                            <div class="font-mono text-[#8B0000] text-sm font-bold border-2 border-[#8B0000] rounded px-3 py-1 -rotate-6 uppercase tracking-widest inline-block opacity-90 text-[10px]">CLASSIFIED</div>
                        </div>
                    </div>
                    
                    <!-- Page 2 -->
                    <div id="visor-page-2" class="flex-1 w-full border-2 border-[#B5935B]/20 p-4 flex flex-col items-center justify-center text-center relative overflow-hidden hidden">
                        <h3 class="font-sans text-xl text-[#F4F1EA] uppercase mb-4 tracking-widest relative z-10 opacity-90">Technical Specs</h3>
                        <p class="font-serif text-[#F4F1EA]/70 text-xs tracking-wide leading-relaxed relative z-10 px-2 text-justify">
                            <strong class="text-[#B5935B] uppercase block text-center mb-2">Visual Inspection & Smart Occupational Relief</strong>
                            Core logic handles realtime stereoscopic rendering for hazard identification. Low-latency edge computing enables sub-millisecond object detection.
                        </p>
                    </div>

                    <!-- Page 3 -->
                    <div id="visor-page-3" class="flex-1 w-full border-2 border-[#B5935B]/20 p-4 flex flex-col items-center justify-center text-center relative overflow-hidden hidden">
                        <h3 class="font-sans text-xl text-[#F4F1EA] uppercase mb-4 tracking-widest relative z-10 opacity-90">System Schematic</h3>
                        <p class="font-mono text-[#B5935B]/50 text-[10px] uppercase tracking-widest border border-[#B5935B]/20 p-4 relative z-10">
                            [Awaiting Blueprint Render]
                        </p>
                    </div>
                    
                    <div class="font-mono text-[8px] text-[#F4F1EA]/30 tracking-widest mt-3 text-center w-full">PG. <span id="visor-page-nav">1</span></div>
                </div>
            </div>
        </div>

        <button onclick="document.getElementById('prospectus-overlay').classList.add('hidden')" class="absolute top-8 right-8 text-sanctum-accent/40 hover:text-sanctum-accent outline-none z-50">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-x"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
        </button>
    </div>
    
    <main class="w-full max-w-6xl relative z-10 transition-all duration-700 ease-[cubic-bezier(0.25,1,0.5,1)] ml-16" id="main-content">
        <%- body %>
    </main>

    <!-- Client-side logic -->
    <script defer src="/js/main.js"></script>
</body>
</html>
